#!/bin/bash

# Function to get git branch
git_br() {
    git branch --show-current 2>/dev/null
}

# Set terminal window title
set_title() {
    echo -ne "\033]2;${HOSTNAME}\007"
}

case "$TERM" in
    xterm-color|*-256color|xterm|alacritty)
        # Title updates before every prompt
        PROMPT_COMMAND='set_title'

        # Slim prompt: just basename + git branch
        PS1="\[\e[0;33m\]\W\[\e[01;37m\] \$(git_br)\[\e[0m\]: "
        ;;
    *)
        # Fallback for dumb terminals — keep everything inline
        PS1="\W @\h \$(git_br): "
        ;;
esac

